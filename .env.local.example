# Server-side only — never exposed to the client.
# Locally: copy to .env.local and fill in.
# On Vercel: set in Project Settings → Environment Variables.
ANTHROPIC_API_KEY=

# Upstash Redis — used for per-IP rate limiting on /api/chat.
# Create a database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
